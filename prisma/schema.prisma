generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  name                  String?
  // The "know yourselves" side-quest card (#73): dismiss-forever is a
  // household decision, so it lives here, never in localStorage.
  sideQuestDismissedAt  DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  profiles              Profile[]
  wholenessScore        WholenessScore?
  automationItems       AutomationItem[]
  checkIns              CheckIn[]
  creditPlan            CreditPlan?
  aggregatorConnections AggregatorConnection[]
  categoryRules         CategoryRule[]
  proposalDecisions     ProposalDecision[]
  calendarSources       CalendarSource[]
  calendarFeedTokens    CalendarFeedToken[]
  inboundEmails         InboundEmail[]
  moneyDates            MoneyDate[]
}

model Profile {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  isDefault      Boolean         @default(false)
  moneyType      MoneyType?
  moneyScripts   MoneyScript[]
  debts          Debt[]
  incomeSources  IncomeSource[]
  bonusItems     BonusItem[]
  spendingPlan   SpendingPlan?
  moneyDials     MoneyDial[]
  linkedAccounts LinkedAccount[]
  events         Event[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId])
}

enum MoneyType {
  OPTIMIZER
  AVOIDER
  WORRIER
  DREAMER
}

model MoneyScript {
  id           String   @id @default(uuid())
  profileId    String
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  promptId     Int
  response     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  aiReflection String?

  @@unique([profileId, promptId])
}

model Debt {
  id             String         @id @default(uuid())
  profileId      String
  profile        Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name           String
  balance        Decimal        @db.Decimal(12, 2)
  apr            Decimal        @db.Decimal(5, 3)
  minimumPayment Decimal        @db.Decimal(10, 2)
  debtType       DebtType
  creditLimit    Decimal?       @db.Decimal(12, 2)
  isShared       Boolean        @default(false)
  // When set, this Debt is mapped to a feed account and the feed owns its balance.
  linkedAccount  LinkedAccount?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([profileId])
}

enum DebtType {
  CREDIT_CARD
  PERSONAL_LOAN
  STUDENT_LOAN
  AUTO_LOAN
  MORTGAGE
  MEDICAL
  OTHER_REVOLVING
  OTHER_INSTALLMENT
}

model IncomeSource {
  id            String   @id @default(uuid())
  profileId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name          String
  monthlyAmount Decimal  @db.Decimal(12, 2)
  isAfterTax    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([profileId])
}

model BonusItem {
  id               String         @id @default(uuid())
  profileId        String
  profile          Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name             String
  grossAmount      Decimal        @db.Decimal(12, 2)
  estimatedTaxRate Decimal        @db.Decimal(5, 2)
  frequency        BonusFrequency @default(ONE_TIME)
  expectedDate     DateTime?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([profileId])
}

enum BonusFrequency {
  ONE_TIME
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

model SpendingPlan {
  id                   String              @id @default(uuid())
  profileId            String              @unique
  profile              Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fixedCostsPercent    Int
  savingsPercent       Int
  investmentsPercent   Int
  guiltFreePercent     Int
  fixedCostsOverridden Boolean             @default(false)
  fixedCostLineItems   FixedCostLineItem[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model FixedCostLineItem {
  id             String            @id @default(uuid())
  spendingPlanId String
  spendingPlan   SpendingPlan      @relation(fields: [spendingPlanId], references: [id], onDelete: Cascade)
  category       FixedCostCategory
  name           String
  monthlyAmount  Decimal           @db.Decimal(10, 2)
  note           String?
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([spendingPlanId])
}

enum FixedCostCategory {
  HOUSING
  INSURANCE
  UTILITIES
  TRANSPORTATION
  SUBSCRIPTIONS
  DEBT_MINIMUMS
  OTHER
}

model MoneyDial {
  id        String       @id @default(uuid())
  profileId String
  profile   Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category  DialCategory
  level     Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([profileId, category])
}

enum DialCategory {
  TRAVEL
  FOOD_DINING
  HEALTH_FITNESS
  CONVENIENCE
  TECHNOLOGY
  FASHION
  EXPERIENCES
  EDUCATION
  GIVING
}

/// Deprecated (#59): the Wholeness Score violated the Honesty Rule and no code
/// reads or writes this model. The table is kept so no destructive migration
/// runs against the live database; dropping it is deferred to a later cleanup.
model WholenessScore {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetScore     Int      @default(0)
  saveScore       Int      @default(0)
  debtScore       Int      @default(0)
  creditScore     Int      @default(0)
  incomeScore     Int      @default(0)
  retirementScore Int      @default(0)
  wealthScore     Int      @default(0)
  insuranceScore  Int      @default(0)
  netWorthScore   Int      @default(0)
  legacyScore     Int      @default(0)
  totalScore      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AutomationItem {
  id          String             @id @default(uuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isCompleted Boolean            @default(false)
  category    AutomationCategory
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId])
}

model CreditPlan {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentScore       Int?
  targetScore        Int?
  targetUtilization  Int      @default(10)
  monitoringEnrolled Boolean  @default(false)
  autopayAllAccounts Boolean  @default(false)
  frozenBureaus      Boolean  @default(false)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum AutomationCategory {
  BILL_PAY
  SAVINGS_TRANSFER
  INVESTMENT_TRANSFER
  CREDIT_PROTECTION
  CREDIT_MONITORING
}

// ---------------------------------------------------------------------------
// Account aggregation (ADR-0001 / ADR-0002)
//
// The app never stores bank credentials. An AggregatorConnection holds only a
// revocable, read-only access secret, encrypted app-side with AES-256-GCM
// under a key that lives exclusively in the AGGREGATOR_TOKEN_KEY env var —
// database contents alone can never reach a bank feed.
// ---------------------------------------------------------------------------

enum ConnectionStatus {
  ACTIVE
  ERROR
  REVOKED
}

enum LinkedAccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  LOAN
  INVESTMENT
  OTHER
}

model AggregatorConnection {
  id                    String           @id @default(uuid())
  userId                String
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              String // "SIMPLEFIN"
  encryptedAccessSecret String // iv.authTag.ciphertext, base64-joined
  status                ConnectionStatus @default(ACTIVE)
  lastSyncAt            DateTime?
  lastSyncError         String?
  linkedAccounts        LinkedAccount[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([userId])
}

model LinkedAccount {
  id             String               @id @default(uuid())
  connectionId   String
  connection     AggregatorConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  externalId     String // provider's account id
  name           String
  institution    String
  accountType    LinkedAccountType
  maskedNumber   String? // provider-masked identifier only; full numbers are never stored
  currentBalance Decimal              @db.Decimal(12, 2)
  balanceAsOf    DateTime
  currency       String               @default("USD")
  profileId      String? // owner profile; null = household/shared
  profile        Profile?             @relation(fields: [profileId], references: [id], onDelete: SetNull)
  mappedDebtId   String?              @unique // Mapping: feed owns this Debt's balance
  mappedDebt     Debt?                @relation(fields: [mappedDebtId], references: [id], onDelete: SetNull)
  transactions   FeedTransaction[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([connectionId, externalId])
}

model FeedTransaction {
  id              String        @id @default(uuid())
  linkedAccountId String
  linkedAccount   LinkedAccount @relation(fields: [linkedAccountId], references: [id], onDelete: Cascade)
  externalId      String
  postedAt        DateTime
  amount          Decimal       @db.Decimal(12, 2) // signed; negative = money out
  description     String
  pending         Boolean       @default(false)

  // Categorization (ADR-0003): a two-level label in the plan's own
  // vocabulary — CSP bucket first, then a Money Dial within Guilt-Free or a
  // fixed-cost category within Fixed Costs. Never a third taxonomy.
  // UNCATEGORIZED stays visible per the Honesty Rule.
  cspBucket            CspBucket             @default(UNCATEGORIZED)
  moneyDial            DialCategory? // second level, only within GUILT_FREE
  fixedCostCategory    FixedCostCategory? // second level, only within FIXED_COSTS
  categorizationSource CategorizationSource?

  // Transfer pairing: the opposite-amount near-in-time leg on another of the
  // household's own Linked Accounts. Transfers are excluded from both
  // spending and income (accrual semantics — card purchases count at the
  // merchant; paying the card later is just a Transfer).
  // Pair integrity (each transaction in at most one pair) is enforced by the
  // pairing code in src/lib/categorization — kept out of the DB so the schema
  // change stays warning-free additive on the live database.
  isTransfer     Boolean @default(false)
  transferPairId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([linkedAccountId, externalId])
  @@index([linkedAccountId, postedAt])
  @@index([linkedAccountId, cspBucket])
  @@index([transferPairId])
}

// Which layer produced a Transaction's Categorization. Deterministic layers
// (MAPPED_DEBT, FIXED_COST_MATCH, RULE) run during sync; CORRECTION and
// BATCH are written by humans and the interval batch job respectively and
// are never overwritten by sync.
enum CategorizationSource {
  MAPPED_DEBT
  FIXED_COST_MATCH
  RULE
  CORRECTION
  BATCH
}

// Level-1 Categorization: the four CSP buckets plus the honest default.
enum CspBucket {
  UNCATEGORIZED
  FIXED_COSTS
  SAVINGS
  INVESTMENTS
  GUILT_FREE
}

// Per-household standing rule: merchant pattern -> Categorization. Every
// Correction becomes one of these, so the same mistake is never made twice;
// the batch job writes rules, not just labels (ADR-0003).
model CategoryRule {
  id                String             @id @default(uuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantPattern   String // normalized substring matched against descriptions
  cspBucket         CspBucket
  moneyDial         DialCategory? // only within GUILT_FREE
  fixedCostCategory FixedCostCategory? // only within FIXED_COSTS
  source            CategoryRuleSource
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, merchantPattern])
}

enum CategoryRuleSource {
  CORRECTION
  BATCH
  SEED
}

// A household's answer to a Proposal (CONTEXT.md): feed-derived drafts are
// never plan data until confirmed, and a dismissal is remembered so the
// same Proposal is never raised twice.
enum ProposalKind {
  FIXED_COST
  DEBT
  INCOME
}

enum ProposalDecisionValue {
  CONFIRMED
  DISMISSED
}

model ProposalDecision {
  id       String                @id @default(uuid())
  userId   String
  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind     ProposalKind
  // Merchant pattern for fixed-cost/income Proposals; LinkedAccount id for
  // Debt Proposals.
  key      String
  decision ProposalDecisionValue

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, kind, key])
}

// ---------------------------------------------------------------------------
// Household Timeline (CONTEXT.md Timeline section; ratified in #32/#33)
//
// An Event is a dated life moment — never a Transaction, never an Earmark
// (though a cost-bearing Event may later *raise* one, only with the
// household's confirmation; hence the optional cost on the model now, the
// confirm flow later). A Calendar Source is where a batch of Events came
// from and owns its own category vocabulary — the app never forces a
// universal Event taxonomy. Imported Events are drafts until ratified: the
// feed drafts, the human ratifies.
// ---------------------------------------------------------------------------

enum CalendarSourceKind {
  IMPORT_PHOTO
  IMPORT_ICS
  MANUAL
  EMAIL_FORWARD
  FEED_DERIVED
}

// DRAFT -> CONFIRMED on ratification; DISMISSED rows are kept so a
// re-import never re-raises a rejected Event (ProposalDecision spirit).
enum EventStatus {
  DRAFT
  CONFIRMED
  DISMISSED
}

model CalendarSource {
  id          String             @id @default(uuid())
  // Household-scoped: the User is the household's single shared login.
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  kind        CalendarSourceKind
  // The artifact's own reissue stamp, verbatim (e.g. "UPDATED 6/3/26").
  sourceStamp String?
  // Per-source category vocabulary (e.g. Corbett's holiday / dismissal /
  // break / event / academic). Another source may differ.
  categories  String[]
  events      Event[]
  feedTokens  CalendarFeedToken[]
  inboundEmails InboundEmail[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId])
}

// Subscribe-once calendar feeds (#90): the token IS the auth — subscription
// clients can't send credentials, so the long random URL is the capability
// (ADR-0001's consent posture, outbound). Revoke = delete the row and every
// subscribed device silently stops updating; rotate = replace the token.
// Money moments are derived live and never stored as Events, so they can
// never leak into a feed.
model CalendarFeedToken {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 32 random bytes, base64url (43 chars) — long enough that the URL is
  // the secret; the unique index makes lookup one indexed probe.
  token            String          @unique
  // null = the whole Household Timeline; set = a single Calendar Source
  // ("just Corbett" for a grandparent or sitter).
  calendarSourceId String?
  calendarSource   CalendarSource? @relation(fields: [calendarSourceId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
}

// The inbound email spine (#69): one row per forwarded email, whatever
// became of it — extraction, deterministic .ics import, or parked with a
// plain-language note. Never silently dropped (Honesty Rule); the raw
// payload lives in Supabase Storage at storagePath.
model InboundEmail {
  id               String             @id @default(uuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Postmark MessageID — webhook retries stay idempotent.
  messageId        String             @unique
  fromAddress      String
  subject          String
  receivedAt       DateTime
  storagePath      String
  status           InboundEmailStatus
  // What happened, in the household's language.
  note             String
  eventsCreated    Int                @default(0)
  calendarSourceId String?
  calendarSource   CalendarSource?    @relation(fields: [calendarSourceId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([userId, createdAt])
}

enum InboundEmailStatus {
  PROCESSED
  PARKED
  FAILED
}

model Event {
  id               String         @id @default(uuid())
  calendarSourceId String
  calendarSource   CalendarSource @relation(fields: [calendarSourceId], references: [id], onDelete: Cascade)
  // Date-only by design (school calendars enumerate days, not times).
  startDate        DateTime       @db.Date
  // Exclusive end (ICS DTEND convention); null = single-day.
  endDate          DateTime?      @db.Date
  title            String
  // Natural-key component for re-import dedup: title lowercased, punctuation
  // stripped, whitespace collapsed (src/lib/timeline/natural-key.ts) — the
  // actions maintain it, never callers.
  normalizedTitle  String
  // One of the owning Calendar Source's categories (validated in actions;
  // per-source vocabularies keep this a String, not an enum).
  category         String
  note             String?
  costCents        Int?
  status           EventStatus    @default(DRAFT)
  // Optional person-tagging (dad's travel, just school); household-wide
  // when null.
  profileId        String?
  profile          Profile?       @relation(fields: [profileId], references: [id], onDelete: SetNull)
  // The two fixed non-Profile assignees (#72) — a nullable enum beats a
  // fake Profile. Mutually exclusive with profileId (the actions enforce
  // it); both null = unassigned.
  assigneeExtra    EventAssigneeExtra?
  // Renewal radar (#70): a handled renewal quiets immediately; null on
  // everything else.
  handledAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([calendarSourceId, startDate, normalizedTitle])
  @@index([calendarSourceId, startDate])
}

enum EventAssigneeExtra {
  SITTER
  EXTENDED_DAY
}

// The Money Date (#81, ratified in #62): raised by paycheck detection,
// one row per Pay Period start. Moved is never skipped — completing a
// RESCHEDULED Date still counts as kept. Beats snapshot what the couple
// actually saw (the cards derive live; the archive remembers).
model MoneyDate {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // The Pay Period's opening payday — the natural key that makes raising
  // idempotent.
  periodStart  DateTime        @db.Date
  status       MoneyDateStatus @default(RAISED)
  // Reschedule target ("our next shared evening"); null until moved.
  scheduledFor DateTime?       @db.Date
  completedAt  DateTime?
  // Who was there, in the household's own words.
  presentNames String[]
  // Snapshot of the four beats as shown at completion.
  beats        Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([userId, periodStart])
  @@index([userId, completedAt])
}

enum MoneyDateStatus {
  RAISED
  RESCHEDULED
  COMPLETED
}

model CheckIn {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month      DateTime
  wentWell   String?
  feltHard   String?
  toAdjust   String?
  creditWins String?
  aiSummary  String?
  createdAt  DateTime @default(now())

  @@unique([userId, month])
}

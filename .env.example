# Site URL (required for OAuth redirects in production)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/richlife"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Anthropic
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Account aggregation (ADR-0002)
# 32-byte AES-256-GCM key for encrypting aggregator access secrets.
# Generate with: openssl rand -base64 32
AGGREGATOR_TOKEN_KEY="your-base64-32-byte-key"
# Shared secret the daily sync cron must present as a Bearer token.
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret"
